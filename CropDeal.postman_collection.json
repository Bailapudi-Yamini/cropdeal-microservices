          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Admin\",\n  \"email\": \"admin@cropdeal.test\",\n  \"password\": \"Password123!\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "04 Login as Farmer → save farmerToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has accessToken', () => pm.expect(body.data.accessToken).to.be.a('string'));",
                  "pm.collectionVariables.set('farmerToken', body.data.accessToken);",
                  "pm.collectionVariables.set('farmerId', body.data.userId);",
                  "console.log('farmerToken saved:', body.data.accessToken.substring(0,20) + '...');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"farmer@cropdeal.test\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "05 Login as Dealer → save dealerToken",
          "event": [
