{
  "info": {
    "name": "CropDeal — Full Happy Path",
    "_postman_id": "cropdeal-collection-v1",
    "description": "Complete end-to-end test: register → login → crop → order → negotiate → payment → notifications → admin.\n\nImport alongside CropDeal.postman_environment.json.\n\nRun in order — each request auto-saves IDs/tokens for the next.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "01 — Auth",
      "item": [
        {
          "name": "01 Register Farmer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('success true', () => pm.expect(body.success).to.be.true);",
                  "pm.collectionVariables.set('farmerEmail', pm.collectionVariables.get('farmerEmail') || 'farmer@cropdeal.test');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Farmer\",\n  \"email\": \"farmer@cropdeal.test\",\n  \"password\": \"Password123!\",\n  \"role\": \"FARMER\",\n  \"phone\": \"9876543210\",\n  \"location\": \"Pune, Maharashtra\"\n}"
            }
          }
        },
        {
          "name": "02 Register Dealer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('success true', () => pm.expect(body.success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Dealer\",\n  \"email\": \"dealer@cropdeal.test\",\n  \"password\": \"Password123!\",\n  \"role\": \"DEALER\",\n  \"phone\": \"9876543211\",\n  \"location\": \"Mumbai, Maharashtra\"\n}"
            }
          }
        },
        {
          "name": "03 Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
