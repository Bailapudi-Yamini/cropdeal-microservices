            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dealer@cropdeal.test\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "06 Login as Admin → save adminToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
