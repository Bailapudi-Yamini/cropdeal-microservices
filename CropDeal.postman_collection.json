        {
          "name": "20 Mark Single Notification Read",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Skip if no notification was saved",
                  "if (!pm.collectionVariables.get('notificationId')) {",
                  "  console.log('No notificationId — skipping');",
                  "  return;",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
