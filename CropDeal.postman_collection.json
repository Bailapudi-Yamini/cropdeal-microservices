    {
      "name": "02 — Crops",
      "item": [
        {
          "name": "07 Farmer Creates Crop Listing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('has crop id', () => pm.expect(body.data.id).to.be.a('number'));",
                  "pm.collectionVariables.set('cropListingId', body.data.id);",
                  "pm.collectionVariables.set('cropPricePerUnit', body.data.pricePerUnit);",
                  "console.log('cropListingId saved:', body.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{farmerToken}}"}
            ],
            "url": "{{baseUrl}}/api/crops",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cropName\": \"Tomato\",\n  \"cropType\": \"VEGETABLE\",\n  \"quantityAvailable\": 500,\n  \"unit\": \"kg\",\n  \"pricePerUnit\": 25.00,\n  \"location\": \"Pune, Maharashtra\",\n  \"description\": \"Fresh organic tomatoes, harvested this week\"\n}"
            }
          }
        },
        {
          "name": "08 Dealer Browses Crops",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has content array', () => pm.expect(body.data.content).to.be.an('array'));",
                  "pm.test('at least 1 crop', () => pm.expect(body.data.content.length).to.be.at.least(1));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{dealerToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/crops?page=0&size=10",
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "09 Dealer Subscribes to VEGETABLE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 or 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{dealerToken}}"}
            ],
            "url": "{{baseUrl}}/api/crops/subscriptions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cropType\": \"VEGETABLE\",\n  \"location\": \"Maharashtra\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "03 — Orders & Negotiation",
      "item": [
        {
          "name": "10 Dealer Places Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('has order id', () => pm.expect(body.data.id).to.be.a('number'));",
                  "pm.collectionVariables.set('orderId', body.data.id);",
                  "pm.collectionVariables.set('orderTotalAmount', body.data.totalAmount);",
                  "console.log('orderId saved:', body.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{dealerToken}}"}
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cropListingId\": {{cropListingId}},\n  \"quantity\": 100\n}"
            }
          }
        },
        {
          "name": "11 Farmer Views Incoming Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has orders', () => pm.expect(body.data.content).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{farmerToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/orders/farmer?page=0&size=10",
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "12 Farmer Counter-Offers (Negotiate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('has negotiation id', () => pm.expect(body.data.id).to.be.a('number'));",
                  "pm.collectionVariables.set('negotiationId', body.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{farmerToken}}"}
            ],
            "url": "{{baseUrl}}/api/orders/{{orderId}}/negotiate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"proposedPrice\": 22.00,\n  \"message\": \"I can offer a slight discount for bulk purchase\"\n}"
            }
          }
        },
        {
          "name": "13 Dealer Accepts Farmer's Price",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('order CONFIRMED', () => pm.expect(body.data.status).to.equal('CONFIRMED'));",
                  "pm.collectionVariables.set('orderTotalAmount', body.data.totalAmount);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{dealerToken}}"}],
            "url": "{{baseUrl}}/api/orders/{{orderId}}/accept"
          }
        },
        {
          "name": "14 Get Negotiation History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has negotiations array', () => pm.expect(body.data).to.be.an('array'));",
                  "pm.test('at least 1 round', () => pm.expect(body.data.length).to.be.at.least(1));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{dealerToken}}"}],
            "url": "{{baseUrl}}/api/orders/{{orderId}}/negotiations"
          }
        }
      ]
    },
    {
      "name": "04 — Payments",
      "item": [
        {
          "name": "15 Check Payment Status by Order ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('payment exists', () => pm.expect(body.data).to.have.property('id'));",
                  "pm.test('status is INITIATED', () => pm.expect(body.data.status).to.equal('INITIATED'));",
                  "pm.collectionVariables.set('paymentId', body.data.id);",
                  "pm.collectionVariables.set('razorpayOrderId', body.data.razorpayOrderId || 'order_mock123');",
                  "console.log('paymentId:', body.data.id, '| razorpayOrderId:', body.data.razorpayOrderId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{dealerToken}}"}],
            "url": "{{baseUrl}}/api/payments/order/{{orderId}}"
          }
        },
        {
          "name": "16 Verify Razorpay Payment (mock — will fail sig check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Signature verification will fail with mock values — that is expected.",
                  "// In real testing, use actual Razorpay test credentials and a real checkout.",
                  "pm.test('Status 200 or 400', () => pm.expect(pm.response.code).to.be.oneOf([200, 400, 422]));",
                  "const body = pm.response.json();",
                  "console.log('Verify response:', JSON.stringify(body));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{dealerToken}}"}
            ],
            "url": "{{baseUrl}}/api/payments/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": {{orderId}},\n  \"razorpayOrderId\": \"{{razorpayOrderId}}\",\n  \"razorpayPaymentId\": \"pay_mock_test_123\",\n  \"razorpaySignature\": \"mock_signature_will_fail_intentionally\"\n}"
            }
          }
        },
        {
          "name": "17 Dealer Views All Payments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{dealerToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/payments/dealer?page=0&size=10",
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        }
      ]
    },
    {
